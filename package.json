{
  "name": "sanity-image",
  "version": "1.1.0",
  "description": "A well-considered React component for displaying images from Sanity with automatic srcSet generation, hotspot/crop support, and more.",
  "author": "Corey Ward <corey@hey.com>",
  "license": "MIT",
  "repository": "https://github.com/coreyward/sanity-image",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "/dist"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@sanity-image/url-builder": "workspace:*"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@size-limit/preset-small-lib": "^12.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.2",
    "@types/probe-image-size": "^7.2.5",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.1",
    "probe-image-size": "^7.2.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "size-limit": "^12.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "pnpm build:url-builder && pnpm build:sanity-image",
    "build:sanity-image": "tsup",
    "build:url-builder": "pnpm --filter @sanity-image/url-builder run build",
    "size": "size-limit",
    "test": "vitest run",
    "test:generate-measurements": "yarn build && yarn node tests/buildTestCases.js",
    "lint": "eslint src/**/*{.ts,.tsx}"
  },
  "engines": {
    "node": ">=22"
  },
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "4 kB"
    },
    {
      "path": "dist/index.mjs",
      "limit": "3 kB"
    }
  ],
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
